# UTILITARE DE ARHIVARE SI COMPRESIE (LINUX)

tar (Tape Archiver)
  - -c (Create): Creeaza o arhiva noua.
      - EX: tar -cf arhiva.tar folder/
  - -x (Extract): Extrage fisierele dintr-o arhiva.
      - EX: tar -xf arhiva.tar
  - -t (List): Afiseaza continutul arhivei fara a o extrage.
      - EX: tar -tf arhiva.tar
  - -z (Gzip): Foloseste compresia gzip (.tar.gz).
      - EX: tar -czf arhiva.tar.gz folder/
  - -j (Bzip2): Folosește compresia bzip2 (.tar.bz2).
      - EX: tar -cjf arhiva.tar.bz2 folder/
  - -f (File): Specifica numele arhivei (obligatoriu inainte de nume).
      - EX: tar -f arhiva.tar
  - -v (Verbose): Afiseaza detaliat progresul operatiunii.
      - EX: tar -cvf arhiva.tar folder/
  - -C (Directory): Specifica directorul de destinatie pentru extractie.
      - EX: tar -xf arhiva.tar -C /home/user/

gzip / gunzip (GNU Zip)
  - -d (Decompress): Despacheteaza un fisier .gz (echivalent cu gunzip).
      - EX: gzip -d fisier.gz
  - -r (Recursive): Comprima toate fisierele dintr-o ierarhie de directoare.
      - EX: gzip -r folder/
  - -k (Keep): Pastreaza fisierul original dupa compresie/extragere.
      - EX: gzip -k fisier.txt

zip / unzip
  - -r (Recursive): Arhiveaza si comprima un director cu tot continutul sau.
      - EX: zip -r arhiva.zip folder/
  - -e (Encrypt): Adauga o parola arhivei create.
      - EX: zip -e arhiva.zip fisier.txt
  - -l (List): Afiseaza continutul arhivei .zip (pentru unzip).
      - EX: unzip -l arhiva.zip


